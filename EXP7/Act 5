class OnlineOrder:
    def __init__(self, order_id, item_price, quantity):
        self.order_id = order_id
        self.item_price = item_price
        self.quantity = quantity

    def calculate_total(self, shipping_fee=5.0):
        subtotal = self.item_price * self.quantity
        return subtotal + shipping_fee

# Example Usage
order = OnlineOrder("ORD123", 25.0, 3)
print(f"Total Order Cost: ${order.calculate_total():.2f}")
